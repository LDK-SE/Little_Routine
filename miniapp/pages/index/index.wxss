.container {
  padding: 40rpx;
}

.header {
  text-align: center;
  margin-top: 80rpx;
  margin-bottom: 60rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 16rpx;
}

.login-tip {
  text-align: center;
  margin-top: 120rpx;
  color: var(--text-secondary);
}

.login-tip button {
  margin-top: 40rpx;
}

.card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-top: 40rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.label {
  color: var(--text-secondary);
}

.value {
  color: var(--text-color);
}
