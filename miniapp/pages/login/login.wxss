.container {
  padding: 40rpx;
}

.header {
  text-align: center;
  margin-top: 100rpx;
  margin-bottom: 60rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-color);
}

.card {
  background: var(--card-bg);
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--text-color);
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
