# ============================================================================
# 3C数码零售系统 · 环境变量示例
# ============================================================================

# ---- 应用 ----
APP_NAME=3c-retail-api
APP_PORT=3000
APP_ENV=development
CORS_ORIGIN=http://localhost:3000,https://your-domain.com

# ---- 数据库 (MySQL 8) ----
DATABASE_URL="mysql://root:password@localhost:3306/3c_retail?charset=utf8mb4"

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT ----
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ---- 日志 ----
LOG_LEVEL=debug

# ---- Swagger ----
SWAGGER_ENABLED=true

# ---- Dify AI 平台 ----
DIFY_BASE_URL=https://dify.your-domain.com/v1
DIFY_API_KEY=app-your-dify-app-key

# ---- Swagger 文档鉴权 (生产环境) ----
# SWAGGER_AUTH=true
# SWAGGER_USER=admin
# SWAGGER_PASS=3c-retail-docs

# ---- Docker Compose ----
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=3c_retail
MYSQL_USER=3capp
MYSQL_PASSWORD=change-me-user-password
