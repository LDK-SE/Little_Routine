# ============================================================================
# 3C数码零售系统 · 环境变量示例
# ============================================================================

# ---- 应用 ----
APP_NAME=3c-retail-api
APP_PORT=3000
APP_ENV=production
CORS_ORIGIN=https://your-domain.com

# ---- 数据库 (MySQL 8) ----
DATABASE_URL="mysql://root:password@localhost:3306/3c_retail?charset=utf8mb4"

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password
REDIS_DB=0

# ---- JWT ----
# 生成方式: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ---- 日志 ----
# 生产环境建议 info，排查问题可临时改为 debug
LOG_LEVEL=info

# ---- Swagger ----
# 生产环境建议关闭或启用鉴权
SWAGGER_ENABLED=false

# ---- Dify AI 平台 ----
DIFY_BASE_URL=https://dify.your-domain.com/v1
DIFY_API_KEY=app-your-dify-app-key

# ---- Swagger 文档鉴权 (生产环境必配) ----
# 如果 SWAGGER_ENABLED=true，必须配置以下三项
SWAGGER_AUTH=true
SWAGGER_USER=your-admin-user
SWAGGER_PASS=your-strong-password

# ---- Docker Compose ----
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=3c_retail
MYSQL_USER=3capp
MYSQL_PASSWORD=change-me-user-password
