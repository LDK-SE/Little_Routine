  // FK
  shop Shop      @relation(fields: [shopId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  rule AlertRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([shopId], map: "idx_shop_id")
  @@index([ruleId], map: "idx_rule_id")
  @@index([alertType], map: "idx_alert_type")
  @@index([level], map: "idx_level")
  @@index([isResolved], map: "idx_is_resolved")
  @@index([createdAt], map: "idx_created_at")
  @@map("alert_log")
}

/// 盘点任务
model StockCheck {
  id             BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  shopId         BigInt           @map("shop_id") @db.UnsignedBigInt
  checkNo        String           @unique @map("check_no") @db.VarChar(30)
  type           StockCheckType
  operatorId     BigInt           @map("operator_id") @db.UnsignedBigInt
  status         StockCheckStatus @default(in_progress)
  expectedCount  Int              @default(0) @map("expected_count")
  actualCount    Int              @default(0) @map("actual_count")
  surplusCount   Int              @default(0) @map("surplus_count")
  deficitCount   Int              @default(0) @map("deficit_count")
  confirmedBy    BigInt?          @map("confirmed_by") @db.UnsignedBigInt
  confirmedAt    DateTime?        @map("confirmed_at") @db.DateTime(0)
  createdAt      DateTime         @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.DateTime(0)

  // FK
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  operator  SysUser  @relation("StockCheckOperator", fields: [operatorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  confirmer SysUser? @relation("StockCheckConfirmer", fields: [confirmedBy], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // 关联
  items StockCheckItem[]

  @@index([shopId], map: "idx_shop_id")
  @@index([operatorId], map: "idx_operator_id")
  @@index([status], map: "idx_status")
  @@index([createdAt], map: "idx_created_at")
  @@map("stock_check")
}

/// 盘点明细
model StockCheckItem {
  id               BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  checkId          BigInt          @map("check_id") @db.UnsignedBigInt
  imei             String          @db.VarChar(20)
  systemStatus     ImeiStatus?     @map("system_status")
  actualStatus     CheckItemStatus @map("actual_status")
  systemLocation   String?         @map("system_location") @db.VarChar(50)
  actualLocation   String?         @map("actual_location") @db.VarChar(50)
  remark           String?         @db.VarChar(200)
  createdAt        DateTime        @default(now()) @map("created_at") @db.DateTime(0)

  // FK (CASCADE 删除盘点任务时联动删除明细)
  check StockCheck @relation(fields: [checkId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([checkId], map: "idx_check_id")
  @@index([imei], map: "idx_imei")
  @@index([actualStatus], map: "idx_actual_status")
  @@map("stock_check_item")
}
