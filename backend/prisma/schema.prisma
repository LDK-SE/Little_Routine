// ============================================================================
// 3C数码零售系统 · Prisma Schema
// ============================================================================
// 版本:     V1.0 (基于 PROJECT_CONTEXT.md §5 + schema.sql)
// 日期:     2026-06-14
// 数据库:   MySQL 8.0.36+
// 引擎:     InnoDB
// 字符集:   utf8mb4 / utf8mb4_unicode_ci
//
// 统计:
//   模型:       32 个
//   枚举:       18 个
//   分区表:     5 个 (sale_order / sale_item / point_ledger / system_log / ai_chat_log)
//               注: Prisma 不原生支持 MySQL 分区, 需在 migration 中手动添加 PARTITION BY RANGE SQL
//   软删除:     7 个 (shop / sys_user / product / product_sku / member / sale_order / return_order)
//   乐观锁:     2 处 (imei_stock.version / member.total_points_version)
//   外键关系:   38 条
//   唯一约束:   18 条
//
// 重要说明:
//   1. MySQL ENUM — Prisma MySQL provider 不支持 @db.Enum, 实际迁移时会生成为 VARCHAR。
//      如需原生 MySQL ENUM, 请使用 `prisma migrate dev --create-only` 后手动修改 migration.sql。
//   2. 分区表 — 5 张表需按 created_at 做 RANGE 分区(每半年)。Prisma 不支持分区,
//      migration 生成后必须手动添加 PARTITION BY RANGE 语句。
//   3. 复合主键 — 分区表使用 @@id([id, createdAt]) 以符合 MySQL 8 分区键必须在所有唯一键中的要求。
//   4. DECIMAL 精度 — 所有金额字段使用 Decimal @db.Decimal(10,2),
//      置信度使用 Decimal @db.Decimal(5,2)。
//   5. 乐观锁 — imei_stock.version 和 member.totalPointsVersion 在应用层通过
//      `WHERE version = ?` 实现, Prisma 仅定义字段, 不处理并发逻辑。
//   6. 软删除 — 7 张表使用 deletedAt DateTime?, 查询时需在应用层添加 `where: { deletedAt: null }`。
//   7. INSERT ONLY — 4 张表(sale_order 财务字段 / sale_item / point_ledger / stock_ledger)
//      应用层禁止暴露 UPDATE/DELETE 方法, Prisma 仍可定义但需在 Service 层限制。
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "relationJoins"]
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "foreignKeys"
}

// ============================================================================
// 枚举定义 (18 个)
// ============================================================================

/// 门店状态
enum ShopStatus {
  open   @map("1")
  closed @map("0")
}

/// 用户状态
enum UserStatus {
  active  @map("1")
  inactive @map("0")
}

/// 产品状态
enum ProductStatus {
  on_sale     @map("1")
  discontinued @map("0")
}

/// IMEI 库存状态
enum ImeiStatus {
  pending_audit
  in_stock
  sold
  returned
  frozen
}

/// IMEI 审核状态
enum AuditStatus {
  pending
  approved
  rejected
}

/// 库存变动类型
enum StockChangeType {
  inbound
  outbound
  return
  check_adjust
}

/// 采购单状态
enum PurchaseStatus {
  pending
  approved
  received
  cancelled
}

/// 积分流水变动类型
enum PointChangeType {
  earn
  redeem
  expire
  referral
  manual_adjust
}

/// 支付方式
enum PaymentMethod {
  cash
  wechat
  alipay
  bank_transfer
  trade_in
  subsidy
  refund
}

/// 支付类型
enum PaymentType {
  normal
  refund
}

/// 对账状态
enum ReconcileStatus {
  pending
  matched
  mismatched
}

/// 退货状态(销售单)
enum ReturnStatus {
  normal
  return_requested
  returning
  returned
}

/// 退货类型
enum ReturnType {
  full_return
  exchange
  refund_only
}

/// 退货审核状态
enum ReturnAuditStatus {
  pending
  approved
  rejected
}

/// 提成类型
enum CommissionType {
  fixed
  percentage
  tiered
}

/// 提成结算状态
enum CommissionSettleStatus {
  pending
  confirmed
  paid
}

/// 国补状态
enum SubsidyStatus {
  pending_submit
  submitted
  under_review
  approved
  rejected
  disbursed
  recalled
}

/// 通知发件箱消息状态
enum OutboxStatus {
  pending
  processing
  published
  failed
}

/// 对账检查类型
enum ReconcileCheckType {
  stock_vs_order
  points_vs_ledger
  payment_vs_order
  subsidy_vs_sales
}

/// 对账结果
enum ReconcileResult {
  pass
  fail
}

/// 积分过期执行状态
enum ExpireStatus {
  success
  partial
  failed
}

/// 预警类型
enum AlertType {
  low_stock
  slow_moving
  price_anomaly
  negative_profit
}

/// 预警级别
enum AlertLevel {
  urgent
  warning
  info
}

/// 盘点类型
enum StockCheckType {
  full
  partial
  category
}

/// 盘点状态
enum StockCheckStatus {
  in_progress
  committed
  confirmed
  cancelled
}

/// 盘点实盘结果
enum CheckItemStatus {
  found
  missing
  extra
  wrong_location
  damaged
}

/// 短信状态
enum SmsStatus {
  pending  @map("0")
  sent     @map("1")
  failed   @map("2")
}

// ============================================================================
// 第一节：基础架构 (4 models)
// ============================================================================

/// 门店/连锁管理 (软删除)
model Shop {
  id            BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  shopNo        String     @unique @map("shop_no") @db.VarChar(20)
  name          String     @db.VarChar(100)
  address       String?    @db.VarChar(200)
  contactPhone  String?    @map("contact_phone") @db.VarChar(11)
  status        ShopStatus @default(open)
  createdAt     DateTime   @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt     DateTime?  @map("deleted_at") @db.DateTime(0)

  // 关联
  users              SysUser[]
  imeiStocks         ImeiStock[]
  stockLedgers       StockLedger[]
  purchaseOrders     PurchaseOrder[]
  saleOrders         SaleOrder[]
  paymentFlows       PaymentFlow[]
  returnOrders       ReturnOrder[]
  tradeInOrders      TradeInOrder[]
  commissionLedgers  CommissionLedger[]
  nationalSubsidies  NationalSubsidy[]
  systemLogs         SystemLog[]
  dailyReconciles    DailyReconcile[]
  alertRules         AlertRule[]
  alertLogs          AlertLog[]
  stockChecks        StockCheck[]

  @@map("shop")
}

/// 角色定义 (RBAC)
model SysRole {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  code        String    @unique @db.VarChar(30)
  name        String    @db.VarChar(50)
  description String?   @db.VarChar(200)
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(0)

  userRoles SysUserRole[]

  @@map("sys_role")
}

/// 系统用户/员工 (软删除)
model SysUser {
  id           BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  shopId       BigInt     @map("shop_id") @db.UnsignedBigInt
  phone        String     @unique @db.VarChar(11)
  name         String     @db.VarChar(50)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  status       UserStatus @default(active)
  createdAt    DateTime   @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt    DateTime?  @map("deleted_at") @db.DateTime(0)

  // FK
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // 关联
  userRoles              SysUserRole[]
  stockLedgers           StockLedger[]         @relation("StockLedgerOperator")
  approvedPurchaseOrders PurchaseOrder[]       @relation("PurchaseOrderApprover")
  saleOrders             SaleOrder[]           @relation("SaleOrderSalesperson")
  returnOrders           ReturnOrder[]         @relation("ReturnOrderAuditor")
  commissionLedgers      CommissionLedger[]    @relation("CommissionLedgerSalesperson")
  confirmedCommissions   CommissionLedger[]    @relation("CommissionLedgerConfirmer")
  auditLogs              AuditLog[]
  systemLogs             SystemLog[]
  dailyResolves          DailyReconcile[]      @relation("DailyReconcileResolver")
  stockChecks            StockCheck[]          @relation("StockCheckOperator")
  confirmedStockChecks   StockCheck[]          @relation("StockCheckConfirmer")

  @@map("sys_user")
}

/// 用户-角色关联 (RBAC 多对多)
model SysUserRole {
  id        BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  userId    BigInt   @map("user_id") @db.UnsignedBigInt
  roleId    BigInt   @map("role_id") @db.UnsignedBigInt
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(0)

  user SysUser @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role SysRole @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([userId, roleId], map: "uk_user_role")
  @@map("sys_user_role")
}

// ============================================================================
// 第二节：商品与库存 (6 models)
// ============================================================================

/// 产品 SPU (软删除)
model Product {
  id        BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  brand     String        @db.VarChar(50)
  model     String        @db.VarChar(100)
  category  String?       @db.VarChar(30)
  status    ProductStatus @default(on_sale)
  createdAt DateTime      @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt DateTime?     @map("deleted_at") @db.DateTime(0)

  // 关联
  skus ProductSku[]

  @@unique([brand, model], map: "uk_brand_model")
  @@index([category], map: "idx_category")
  @@index([status], map: "idx_status")
  @@index([deletedAt], map: "idx_deleted_at")
  @@index([brand, model, status], map: "idx_brand_model_status")
  @@map("product")
}

/// 产品规格 SKU (软删除, 连锁共用)
model ProductSku {
  id           BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  productId    BigInt        @map("product_id") @db.UnsignedBigInt
  color        String        @db.VarChar(30)
  spec         String        @db.VarChar(50)
  barcode      String?       @db.VarChar(50)
  retailPrice  Decimal?      @map("retail_price") @db.Decimal(10, 2)
  minSalePrice Decimal?      @map("min_sale_price") @db.Decimal(10, 2)
  status       ProductStatus @default(on_sale)
  createdAt    DateTime      @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt    DateTime?     @map("deleted_at") @db.DateTime(0)

  // FK
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // 关联
  imeiStocks    ImeiStock[]
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  alertRules    AlertRule[]

  @@unique([productId, color, spec], map: "uk_product_color_spec")
  @@index([barcode], map: "idx_barcode")
  @@index([status], map: "idx_status")
  @@index([deletedAt], map: "idx_deleted_at")
  @@map("product_sku")
}

/// IMEI 库存主表 (乐观锁: version)
model ImeiStock {
  id          BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  shopId      BigInt      @map("shop_id") @db.UnsignedBigInt
  skuId       BigInt      @map("sku_id") @db.UnsignedBigInt
  imei        String      @unique @db.VarChar(20)
  batchNo     String?     @map("batch_no") @db.VarChar(50)
  location    String?     @db.VarChar(50)
  costPrice   Decimal?    @map("cost_price") @db.Decimal(10, 2)
  channel     String?     @db.VarChar(50)
  status      ImeiStatus  @default(pending_audit)
  auditStatus AuditStatus @default(pending) @map("audit_status")
  version     Int         @default(0) @db.UnsignedInt
  createdAt   DateTime    @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.DateTime(0)

  // FK
  shop Shop       @relation(fields: [shopId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sku  ProductSku @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // 关联 (按 imei 字段引用)
  stockLedgers    StockLedger[]
  saleItems       SaleItem[]
  returnOrders    ReturnOrder[]
  nationalSubsidies NationalSubsidy[]
  auditLogs       AuditLog[]

  @@index([shopId], map: "idx_shop_id")
  @@index([skuId], map: "idx_sku_id")
  @@index([status], map: "idx_status")
  @@index([auditStatus], map: "idx_audit_status")
  @@index([location], map: "idx_location")
  @@index([batchNo], map: "idx_batch_no")
  @@index([shopId, status], map: "idx_shop_status")
  @@index([skuId, status], map: "idx_sku_status")
  @@index([status, location], map: "idx_status_location")
  @@map("imei_stock")
}

/// 库存变动流水 (INSERT ONLY)
model StockLedger {
  id          BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  shopId      BigInt          @map("shop_id") @db.UnsignedBigInt
  imei        String          @db.VarChar(20)
  changeType  StockChangeType @map("change_type")
  fromStatus  String?         @map("from_status") @db.VarChar(20)
  toStatus    String          @map("to_status") @db.VarChar(20)
  operatorId  BigInt          @map("operator_id") @db.UnsignedBigInt
  orderNo     String?         @map("order_no") @db.VarChar(30)
  remark      String?         @db.VarChar(200)
  createdAt   DateTime        @default(now()) @map("created_at") @db.DateTime(0)

  // FK
  shop     Shop    @relation(fields: [shopId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  imeiRef  ImeiStock @relation(fields: [imei], references: [imei], onDelete: Restrict, onUpdate: Cascade)
  operator SysUser @relation("StockLedgerOperator", fields: [operatorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([imei], map: "idx_imei")
  @@index([shopId], map: "idx_shop_id")
  @@index([changeType], map: "idx_change_type")
  @@index([operatorId], map: "idx_operator_id")
  @@index([orderNo], map: "idx_order_no")
  @@index([createdAt], map: "idx_created_at")
  @@index([imei, createdAt], map: "idx_imei_created")
  @@index([shopId, changeType, createdAt], map: "idx_shop_type_created")
  @@map("stock_ledger")
}

/// 采购订单 (软删除)
model PurchaseOrder {
  id              BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  shopId          BigInt         @map("shop_id") @db.UnsignedBigInt
  orderNo         String         @unique @map("order_no") @db.VarChar(30)
  supplierName    String?        @map("supplier_name") @db.VarChar(100)
  supplierContact String?        @map("supplier_contact") @db.VarChar(50)
  totalAmount     Decimal        @default(0.00) @map("total_amount") @db.Decimal(10, 2)
  status          PurchaseStatus @default(pending)
  approvedBy      BigInt?        @map("approved_by") @db.UnsignedBigInt
  approvedAt      DateTime?      @map("approved_at") @db.DateTime(0)
  receivedAt      DateTime?      @map("received_at") @db.DateTime(0)
  remark          String?        @db.VarChar(200)
  createdAt       DateTime       @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt       DateTime?      @map("deleted_at") @db.DateTime(0)

  // FK
  shop     Shop     @relation(fields: [shopId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  approver SysUser? @relation("PurchaseOrderApprover", fields: [approvedBy], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // 关联
  items PurchaseItem[]

  @@index([shopId], map: "idx_shop_id")
  @@index([status], map: "idx_status")
  @@index([createdAt], map: "idx_created_at")
  @@index([deletedAt], map: "idx_deleted_at")
  @@index([shopId, status], map: "idx_shop_status")
  @@map("purchase_order")
}

/// 采购明细
model PurchaseItem {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  purchaseOrderId BigInt   @map("purchase_order_id") @db.UnsignedBigInt
  skuId           BigInt   @map("sku_id") @db.UnsignedBigInt
  imei            String   @db.VarChar(20)
  quantity        Int      @default(1)
  unitCost        Decimal  @map("unit_cost") @db.Decimal(10, 2)
  subtotal        Decimal  @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.DateTime(0)

  // FK
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sku           ProductSku    @relation(fields: [skuId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([purchaseOrderId], map: "idx_po_id")
  @@index([skuId], map: "idx_sku_id")
  @@index([imei], map: "idx_imei")
  @@index([purchaseOrderId, skuId], map: "idx_po_sku")
  @@map("purchase_item")
}

// ============================================================================
// 第三节：会员与积分 (3 models)
// ============================================================================

/// 会员表 (软删除, 乐观锁: totalPointsVersion, 连锁通用)
model Member {
  id                 BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  phone              String     @unique @db.VarChar(11)
  name               String?    @db.VarChar(50)
  address            String?    @db.VarChar(200)
  licensePlate       String?    @map("license_plate") @db.VarChar(20)
  backupPhone        String?    @map("backup_phone") @db.VarChar(11)
  lastPurchaseModel  String?    @map("last_purchase_model") @db.VarChar(100)
  totalPoints        Int        @default(0) @map("total_points")
  totalPointsVersion Int        @default(0) @map("total_points_version") @db.UnsignedInt
  referrerId         BigInt?    @map("referrer_id") @db.UnsignedBigInt
  status             UserStatus @default(active)
  createdAt          DateTime   @default(now()) @map("created_at") @db.DateTime(0)
  updatedAt          DateTime   @updatedAt @map("updated_at") @db.DateTime(0)
  deletedAt          DateTime?  @map("deleted_at") @db.DateTime(0)

  // 自引用 FK (推荐人, 仅一级)
  referrer Member?  @relation("MemberReferrer", fields: [referrerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  referrals Member[] @relation("MemberReferrer")

  // 关联
  pointLedgers       PointLedger[]
  referralAsReferrer MemberReferral[] @relation("ReferralReferrer")
  referralAsReferee  MemberReferral[] @relation("ReferralReferee")
  saleOrders         SaleOrder[]
  smsLogs            SmsLog[]
  pointsExpireLogs   PointsExpireLog[]

  @@index([referrerId], map: "idx_referrer_id")
  @@index([status], map: "idx_status")
  @@index([createdAt], map: "idx_created_at")
  @@index([deletedAt], map: "idx_deleted_at")
  @@map("member")
}

/// 推荐关系表 (仅一级推荐)
model MemberReferral {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  referrerId      BigInt    @map("referrer_id") @db.UnsignedBigInt
  refereeId       BigInt    @map("referee_id") @db.UnsignedBigInt
  rewardGranted   Boolean   @default(false) @map("reward_granted") @db.TinyInt
  rewardGrantedAt DateTime? @map("reward_granted_at") @db.DateTime(0)
  createdAt       DateTime  @default(now()) @map("created_at") @db.DateTime(0)

  // FK
  referrer Member @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  referee  Member @relation("ReferralReferee", fields: [refereeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([referrerId, refereeId], map: "uk_referrer_referee")
  @@index([refereeId], map: "idx_referee_id")
  @@map("member_referral")
}

/// 积分流水 (INSERT ONLY, FIFO过期, 分区表)
/// ⚠️ 分区表: 需在 migration 中手动添加 PARTITION BY RANGE (TO_DAYS(created_at))
model PointLedger {
  id               BigInt          @default(autoincrement()) @db.UnsignedBigInt
  memberId         BigInt          @map("member_id") @db.UnsignedBigInt
  changeType       PointChangeType @map("change_type")
  amount           Int
  balanceAfter     Int             @map("balance_after")
  orderNo          String?         @map("order_no") @db.VarChar(30)
  orderTime        DateTime?       @map("order_time") @db.DateTime(0)
  productModel     String?         @map("product_model") @db.VarChar(100)
  unitPrice        Decimal?        @map("unit_price") @db.Decimal(10, 2)
  quantity         Int             @default(1)
  expiresAt        DateTime?       @map("expires_at") @db.Date
  expiredAmount    Int             @default(0) @map("expired_amount")
  remainingAmount  Int             @map("remaining_amount")
  remark           String?         @db.VarChar(200)
  createdAt        DateTime        @default(now()) @map("created_at") @db.DateTime(0)

  // FK
  member Member @relation(fields: [memberId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // 复合主键 (MySQL 8 分区要求)
  @@id([id, createdAt])
  @@index([memberId], map: "idx_member_id")
  @@index([orderNo], map: "idx_order_no")
  @@index([changeType], map: "idx_change_type")
  @@index([expiresAt], map: "idx_expires_at")
  @@index([memberId, changeType, createdAt], map: "idx_member_type_created")
  @@index([memberId, expiresAt, remainingAmount], map: "idx_member_expires_remaining")
  @@map("point_ledger")
}

// ============================================================================
// 第四节：销售与财务 (5 models)
// ============================================================================

/// 销售订单 (财务字段 INSERT ONLY, 软删除, 分区表)
/// ⚠️ 分区表: 需在 migration 中手动添加 PARTITION BY RANGE (TO_DAYS(created_at))
/// ⚠️ order_no 在业务上是全局唯一的(雪花ID),
///    MySQL DDL 出于分区要求使用复合 UK (order_no, created_at),
///    Prisma 中标记为 @unique 以支持 FK 引用
model SaleOrder {
  id                BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  shopId            BigInt        @map("shop_id") @db.UnsignedBigInt
  orderNo           String        @unique @map("order_no") @db.VarChar(30)
  memberId          BigInt?       @map("member_id") @db.UnsignedBigInt
  salespersonId     BigInt        @map("salesperson_id") @db.UnsignedBigInt
  totalAmount       Decimal       @map("total_amount") @db.Decimal(10, 2)
